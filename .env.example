# Jossie Eyes - Environment Configuration
# Copy this file to .env and fill in your values

# Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://your-openai-service.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-api-key
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Services (Speech & Computer Vision)
AZURE_SPEECH_KEY=your-speech-api-key
AZURE_SPEECH_REGION=westeurope

# Azure Subscription (optional, for deployment scripts)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-jossie-eyes

# Raspberry Pi Configuration (optional)
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
AUDIO_VOLUME=1.0

# Logging
LOG_LEVEL=INFO