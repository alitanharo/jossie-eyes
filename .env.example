# Jossie Eyes - Environment Configuration
# Copy this file to .env and fill in your values

# OpenAI API (for GPT-4o Vision)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Services (Speech & Computer Vision)
# Created by Azure deployment
AZURE_SPEECH_KEY=your-speech-api-key
AZURE_SPEECH_REGION=northeurope

# Azure Subscription (optional, for deployment scripts)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-jossie-eyes

# Raspberry Pi Configuration (optional)
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
AUDIO_VOLUME=1.0

# Logging
LOG_LEVEL=INFO